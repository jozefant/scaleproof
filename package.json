{
  "name": "scaleproof",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Evidence-based codebase scale readiness for founders.",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "npm run typecheck:ts6 && npm run typecheck:ts7",
    "typecheck:ts6": "tsc6 --noEmit --stableTypeOrdering",
    "typecheck:ts7": "node ./node_modules/typescript-7/bin/tsc --noEmit",
    "typecheck:ts7:single": "node ./node_modules/typescript-7/bin/tsc --noEmit --singleThreaded",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "capture:media": "node ./scripts/capture-public-media.mjs",
    "verify": "npm run lint && npm run typecheck && npm test && npm run build && npm run test:e2e"
  },
  "engines": {
    "node": "^22.11.0"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@tailwindcss/postcss": "^4.3.3",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "openai": "^6.48.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "tailwindcss": "^4.3.3",
    "tar": "^7.5.20",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-7": "npm:typescript@^7.0.2",
    "vitest": "^4.1.10"
  }
}
